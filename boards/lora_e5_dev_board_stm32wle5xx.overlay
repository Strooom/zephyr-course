#include <zephyr/dt-bindings/led/led.h>

/ {
    aliases {
        led-strip = &led_strip;
    };
};

&spi2 {
    status = "okay";

    led_strip: ws2812@0 {
        compatible = "worldsemi,ws2812-spi";
        reg = <0>;
        spi-max-frequency = <6400000>;
        chain-length = <4>;
        color-mapping = <LED_COLOR_ID_GREEN  LED_COLOR_ID_RED LED_COLOR_ID_BLUE>;
        spi-one-frame = <0x78>;
        spi-zero-frame = <0x60>;
    };
};